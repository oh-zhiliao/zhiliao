# Build image: all deps installed, no source code.
# Rebuild only when package.json changes.
#
# Used for:
#   - Quick deploy: mount source at runtime, tsx runs TS directly
#   - Full deploy: base layer for Dockerfile (compile + prune → release image)
#
# Build:
#   docker build -f Dockerfile.base -t zhiliao-build .
ARG BASE_IMAGE=node:22-slim

FROM ${BASE_IMAGE}
ARG USE_CN_MIRROR=false
RUN if [ "$USE_CN_MIRROR" = "true" ]; then \
      sed -i 's|deb.debian.org|mirrors.aliyun.com|g' /etc/apt/sources.list.d/debian.sources; \
    fi \
    && apt-get update && apt-get install -y --no-install-recommends \
       git openssh-client python3 make g++ \
    && rm -rf /var/lib/apt/lists/* \
    && git config --global safe.directory '*'

WORKDIR /app
COPY package.json package-lock.json ./
RUN if [ "$USE_CN_MIRROR" = "true" ]; then \
      npm ci --registry=https://registry.npmmirror.com; \
    else \
      npm ci; \
    fi

COPY entrypoint.sh /app/entrypoint.sh

ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["node", "--import", "tsx/esm", "src/index.ts", "/app/config.yaml"]
